{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gorkX",
  "version": "0.3.7",
  "identifier": "app.gorkx.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "gorkX",
        "width": 1440,
        "height": 900,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/zh-Hans.lproj": "zh-Hans.lproj",
      "resources/en.lproj": "en.lproj"
    },
    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "12.0"
    }
  }
}
