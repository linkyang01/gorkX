+/// Return only the session's authentication category and the safe desktop
+/// destination for managing it.  Never expose a token, token suffix, user id,
+/// or credential path through ACP.
+fn session_auth_summary(agent: &MvpAgent) -> (&'static str, &'static str) {
+    let selected = agent.auth_method_id.load();
+    let source = match selected.as_deref().map(|id| id.0.as_ref()) {
+        Some("xai.api_key") => "api_key",
+        Some("grok.com" | "oidc" | "cached_token") => "oauth",
+        Some(_) => "external",
+        None => match agent.auth_manager.current().as_ref().map(|auth| &auth.auth_mode) {
+            Some(crate::auth::AuthMode::ApiKey) => "api_key",
+            Some(crate::auth::AuthMode::WebLogin | crate::auth::AuthMode::Oidc) => "oauth",
+            Some(crate::auth::AuthMode::External) => "external",
+            None => "not_authenticated",
+        },
+    };
+    let management = match source {
+        "api_key" | "external" => "models",
+        "oauth" | "not_authenticated" => "account",
+        _ => "account",
+    };
+    (source, management)
+}
+
